# Copy to .env at project root.
# Base URL for Node/Express backend API
VITE_API_BASE_URL=http://localhost:5001

# Node/Express API
PORT=5001
CLIENT_ORIGIN=http://localhost:8080
MONGODB_URI=mongodb://127.0.0.1:27017/mindsupport
MONGODB_DATABASE=mindsupport
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Optional: seed a manual admin account. Keep the real password in local/Render env only.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=MindSupport Admin

# Optional: use a fixed Google Meet room link for online sessions.
# If unset, the app opens https://meet.google.com/new for counsellors.
GOOGLE_MEET_DEFAULT_LINK=

# Optional: YouTube Data API v3 key for live wellness videos in Resources.
# Keep the real key in Render/local env only; do not commit it.
YOUTUBE_API_KEY=
